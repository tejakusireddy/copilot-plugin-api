# Azure OpenAI — required
# Uses ASP.NET Core double-underscore convention: AzureOpenAI__Key maps to AzureOpenAI:Key
AzureOpenAI__ApiKey=
AzureOpenAI__Endpoint=
AzureOpenAI__PrimaryDeployment=gpt-4o
AzureOpenAI__FallbackDeployment=gpt-4o-mini

# Database — optional, defaults to sqlite
DATABASE_PROVIDER=sqlite
DATABASE_CONNECTION_STRING=Data Source=copilot.db

# Redis — optional, overrides appsettings.json default
Redis__ConnectionString=localhost:6379

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
